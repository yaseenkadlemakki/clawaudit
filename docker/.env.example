# ── ClawAudit Docker Environment ─────────────────────────────────────────────
# Copy to docker/.env and fill in values before running:
#   cp docker/.env.example docker/.env
#   docker compose --env-file docker/.env -f docker/docker-compose.yml up

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=clawaudit
POSTGRES_USER=clawaudit
POSTGRES_PASSWORD=changeme_use_a_strong_password

# ── Ports (change if defaults clash) ─────────────────────────────────────────
API_PORT=18790
UI_PORT=3000

# ── Backend ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Comma-separated list of origins the API allows CORS from
CORS_ORIGINS=http://localhost:3000

# ── OpenClaw Gateway (OpenClaw mode chat) ─────────────────────────────────────
# URL of your running OpenClaw gateway (from the host or another container)
OPENCLAW_GATEWAY_URL=http://host.docker.internal:18789
# Bearer token from ~/.openclaw/openclaw.json → gateway.token
OPENCLAW_GATEWAY_TOKEN=

# ── BYOLLM (direct Anthropic mode chat) ──────────────────────────────────────
# Model to use when calling Anthropic directly (BYOLLM mode)
BYOLLM_MODEL=claude-haiku-4-5

# ── Frontend build args ───────────────────────────────────────────────────────
# These are baked into the Next.js build — change requires rebuild
NEXT_PUBLIC_API_URL=http://localhost:18790
NEXT_PUBLIC_WS_URL=ws://localhost:18790
